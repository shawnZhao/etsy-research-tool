ETSY_API_KEY=your_etsy_keystring_here
ETSY_API_SECRET=your_etsy_shared_secret_here
ETSY_ACCESS_TOKEN=  # OAuth PKCE 获取，自动存入 Redis
ETSY_REFRESH_TOKEN=  # OAuth PKCE 获取，自动存入 Redis
ETSY_PROXY_URL=  # 国内访问 Etsy API 需要代理，如 socks5://host.docker.internal:7890
DATABASE_URL=postgresql+asyncpg://etsy:etsy_dev@localhost:5432/etsy_research
DATABASE_URL_SYNC=postgresql://etsy:etsy_dev@localhost:5432/etsy_research
REDIS_URL=redis://localhost:6379/0
